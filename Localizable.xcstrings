    "I truly appreciate your wish to support the project, but the purchase could not be completed. Please try again later." : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cijenim Vašu želju da podržite projekt, ali kupnju nije bilo moguće dovršiti. Pokušajte ponovno poslije."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я очень ценю Ваше желание поддержать проект, но покупку не удалось завершить. Пожалуйста, повторите попытку позже."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я дуже ціную Ваше бажання підтримати проєкт, але покупку не вдалося завершити. Будь ласка, повторіть спробу пізніше."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Velmi si vážím vaší snahy podpořit projekt, ale nákup se nepodařilo dokončit. Zkuste to prosím později."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veľmi si vážim vašu snahu podporiť projekt, ale nákup sa nepodarilo dokončiť. Skúste to, prosím, neskôr."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Искрено оценявам желанието ви да подкрепите проекта, но покупката не можа да бъде завършена. Моля, опитайте отново по-късно."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Искрено ја ценам вашата желба да го поддржите проектот, но купувањето не можеше да се заврши. Обидете се повторно подоцна."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я вельмі цаню ваша жаданне падтрымаць праект, але куплю не ўдалося завяршыць. Калі ласка, паўтарыце спробу пазней."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iskreno cenim vašo željo podpreti projekt, vendar nakupa ni bilo mogoče dokončati. Poskusite znova pozneje."
          }
        }
      }
    },
