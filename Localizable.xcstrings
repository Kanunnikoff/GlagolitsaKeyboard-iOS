    "Ability to enable system font and sound when pressing keys." : {
      "extractionState" : "stale",
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mogućnost odabira fonta i uključenja zvuka pri tipkanju."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Возможность включения системного шрифта и звука при нажатии клавиш."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можливість увімкнення системного шрифту та звуку при натисканні клавіш."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Možnost zapnout systémové písmo a zvuk při stisknutí kláves."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Možnosť zapnúť systémové písmo a zvuk pri stlačení klávesov."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Възможност за включване на системния шрифт и звука при натискане на клавишите."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можност за вклучување на системскиот фонт и звукот при притискање на копчињата."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Магчымасць уключыць сістэмны шрыфт і гук пры націсканні клавіш."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Možnost vklopa sistemske pisave in zvoka ob pritisku tipk."
          }
        }
      }
