    "If you like the result of my work, then you can, if you wish, support me in one of the above ways." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you like the result of my work, then you can, if you wish, support me in one of the above ways."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako cijenite moj rad, možete ako to želite mi dati podršku na jedan od navedenih načina."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если Вам нравится результат моего труда, то Вы можете, при желании, поддержать меня одним из вышеперечисленных способов."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо Вам подобається результат моєї праці, то Ви можете, за бажання, підтримати мене одним із перерахованих вище способів."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud se vám výsledek mé práce líbí, můžete mě podpořit některým z výše uvedených způsobů."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak sa vám výsledok mojej práce páči, môžete ma podporiť niektorým z vyššie uvedených spôsobov."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако харесвате резултата от работата ми, можете да ме подкрепите по един от посочените по-горе начини."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако ви се допаѓа резултатот од мојата работа, можете да ме поддржите на еден од горенаведените начини."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Калі вам падабаецца вынік маёй працы, вы можаце падтрымаць мяне адным з пералічаных вышэй спосабаў."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Če vam je rezultat mojega dela všeč, me lahko podprete na enega od zgoraj navedenih načinov."
          }
        }
      }
    },
    "If you like the result of my work, you can support me with a tip." : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako Vam se sviđa rezultat mojeg rada, možete me podržati napojnicom."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если Вам нравится результат моего труда, Вы можете поддержать меня чаевыми."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо Вам подобається результат моєї праці, Ви можете підтримати мене чайовими."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud se vám výsledek mé práce líbí, můžete mě podpořit spropitným."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak sa vám výsledok mojej práce páči, môžete ma podporiť prepitným."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако харесвате резултата от работата ми, можете да ме подкрепите с бакшиш."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако ви се допаѓа резултатот од мојата работа, можете да ме поддржите со бакшиш."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Калі вам падабаецца вынік маёй працы, вы можаце падтрымаць мяне чаявымі."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Če vam je rezultat mojega dela všeč, me lahko podprete z napitnino."
          }
        }
      }
    },
    "In any regular text field, hold the keyboard switch key and select “Glagolitic”." : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "U bilo kojem običnom polju za unos držite tipku za promjenu tipkovnice i odaberite „Glagolitic”."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В любом обычном поле ввода удерживайте кнопку переключения клавиатур и выберите «Глаголица»."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У будь-якому звичайному полі введення утримуйте кнопку перемикання клавіатур і виберіть «Глаголиця»."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V libovolném běžném textovém poli podržte klávesu pro přepínání klávesnic a vyberte „Hlaholice“."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V ľubovoľnom bežnom textovom poli podržte kláves na prepínanie klávesníc a vyberte „Hlaholika“."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В произволно обикновено текстово поле задръжте бутона за смяна на клавиатурата и изберете „Глаголица“."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Во кое било обично поле за текст, задржете го копчето за менување тастатура и изберете „Глаголица“."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У любым звычайным тэкставым полі ўтрымлівайце клавішу пераключэння клавіятур і выберыце «Глаголіца»."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V poljubnem običajnem besedilnem polju pridržite tipko za preklop tipkovnice in izberite »Glagolica«."
          }
        }
      }
    },
    "In case of questions or suggestions, I am at your service. Let's be in touch!" : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "U slučaju pitanja ili prijedloga, na usluzi sam Vam. Budimo u kontaktu!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В случае вопросов или предложений, я к Вашим услугам. Будем на связи!"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У разі запитань чи пропозицій я до Ваших послуг. Будемо на зв'язку!"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Máte-li dotazy nebo návrhy, jsem vám k dispozici. Zůstaňme v kontaktu!"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak máte otázky alebo návrhy, som vám k dispozícii. Zostaňme v kontakte!"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако имате въпроси или предложения, съм на ваше разположение. Нека поддържаме връзка!"
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ако имате прашања или предлози, ви стојам на располагање. Да останеме во контакт!"
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Калі ў вас ёсць пытанні ці прапановы, я да вашых паслуг. Будзем на сувязі!"
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Če imate vprašanja ali predloge, sem vam na voljo. Ostanimo v stiku!"
          }
        }
      }
    },
    "iOS uses the system keyboard in password and phone-number fields. Some apps may also block third-party keyboards." : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "U poljima za lozinku i telefonski broj iOS prikazuje sustavnu tipkovnicu. Neke aplikacije mogu blokirati i tipkovnice drugih proizvođača."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В полях пароля и номера телефона iOS показывает системную клавиатуру. Некоторые приложения также могут запрещать сторонние клавиатуры."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У полях пароля та номера телефону iOS показує системну клавіатуру. Деякі застосунки також можуть забороняти сторонні клавіатури."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V polích pro heslo a telefonní číslo používá iOS systémovou klávesnici. Některé aplikace mohou blokovat také klávesnice jiných výrobců."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V poliach pre heslo a telefónne číslo používa iOS systémovú klávesnicu. Niektoré aplikácie môžu blokovať aj klávesnice iných výrobcov."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В полетата за парола и телефонен номер iOS използва системната клавиатура. Някои приложения може също да блокират клавиатури на други разработчици."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Во полињата за лозинка и телефонски број iOS ја користи системската тастатура. Некои апликации може да блокираат и тастатури од други создавачи."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У палях пароля і нумара тэлефона iOS выкарыстоўвае сістэмную клавіятуру. Некаторыя праграмы таксама могуць блакіраваць староннія клавіятуры."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V poljih za geslo in telefonsko številko iOS uporablja sistemsko tipkovnico. Nekatere aplikacije lahko blokirajo tudi tipkovnice drugih ponudnikov."
          }
        }
      }
    },
