    "Letters that do not fit on the main layout are available by holding the corresponding keys." : {
      "localizations" : {
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slova koja nisu na glavnom rasporedu dostupna su dugim pritiskom odgovarajućih tipki."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буквы, не поместившиеся в основную раскладку, доступны по долгому удержанию соответствующих клавиш."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Літери, що не вмістилися в основній розкладці, доступні за довгим утриманням відповідних клавіш."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Písmena, která se nevejdou do hlavního rozložení, jsou dostupná podržením příslušných kláves."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Písmená, ktoré sa nezmestia do hlavného rozloženia, sú dostupné podržaním príslušných klávesov."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буквите, които не се побират в основната подредба, са достъпни чрез задържане на съответните клавиши."
          }
        },
        "mk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буквите што не се вклопуваат во главниот распоред се достапни со задржување на соодветните копчиња."
          }
        },
        "be" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Літары, якія не змяшчаюцца ў асноўнай раскладцы, даступныя пры ўтрыманні адпаведных клавіш."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Črke, ki ne sodijo v glavno razporeditev, so dostopne s pridržanjem ustreznih tipk."
          }
        }
      }
    },
